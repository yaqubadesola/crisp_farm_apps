# Alternative: use this instead of deploy.yml if you choose Fly.io (no cold starts).
# Rename to deploy.yml and delete the Render version.
#
# Prerequisites:
#   flyctl auth token  →  save as GITHUB secret FLY_API_TOKEN
#   Run once locally:  cd backend && flyctl launch   (creates fly.toml)

name: Deploy (Fly.io)

on:
  push:
    branches: [main]
    paths:
      - 'backend/**'

jobs:
  deploy-backend:
    name: Deploy Backend → Fly.io
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - name: Set up flyctl
        uses: superfly/flyctl-actions/setup-flyctl@master

      - name: Deploy
        working-directory: backend
        run: flyctl deploy --remote-only
        env:
          FLY_API_TOKEN: ${{ secrets.FLY_API_TOKEN }}
