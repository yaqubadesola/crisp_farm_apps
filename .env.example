# Copy this file to .env and fill in your values.
# Never commit .env — it is in .gitignore.

# ── Database ─────────────────────────────────────────────────────────────
DB_URL=jdbc:postgresql://localhost:5432/farm_db
DB_USERNAME=farm_user
DB_PASSWORD=farm_pass

# ── JWT ───────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 40
JWT_SECRET=replace-with-a-long-random-string-at-least-32-chars

# Token lifetime in milliseconds.
# 1800000 = 30 min (recommended for production)
# 86400000 = 24 hours (convenient for development)
JWT_EXPIRATION_MS=1800000

# ── CORS ──────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (no trailing slash).
# Production example:
#   ALLOWED_ORIGINS=https://your-app.vercel.app,https://your-app-git-develop-xxx.vercel.app
ALLOWED_ORIGINS=http://localhost:3000

# ── Admin seed account ────────────────────────────────────────────────────
# Only used on the very first startup when no tenant exists.
# Change this before deploying. Once the account is created, this value
# has no effect (re-seeding is skipped).
ADMIN_INITIAL_PASSWORD=replace-with-a-strong-password

# ── Frontend (Next.js build-time) ─────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8080/api
